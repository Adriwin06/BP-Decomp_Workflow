# Coordination config for the BP work server (community concurrency is the default).
#
# Setup: copy this file to `.env` and set WORK_AGENT to a unique id for yourself.
# `work` loads `.env` from the repo root automatically. A real shell environment
# variable always overrides what is set here.
#
#   cp .env.example .env      # then edit WORK_AGENT below
#
# Never commit `.env` (it is git-ignored); only this example is tracked.

# Coordination server URL. OPTIONAL and invite-only: leave this unset/commented to
# work locally (the default — ledger + git only, same as a solo workflow). ONLY set it
# if the project maintainer gave you a server URL; then you coordinate claims with the
# others who were given the same URL.
# WORK_SERVER=http://your-server.com

# Only used in server mode: a unique id so the server can attribute your claims.
WORK_AGENT=changeme-unique-agent-id

# How long a claim lease lasts before the server returns abandoned work to `todo`.
WORK_LEASE_SECONDS=7200

# Only needed for admin operations (`work server-reset`, `/admin/*`). Usually blank.
# WORK_ADMIN_TOKEN=
